{
	"name": "lovable-clone",
	"version": "1.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "mprocs \"pnpm run dev:next\" \"pnpm run dev:webhook\" \"pnpm run dev:inngest\" \"pnpm run db:studio\"",
		"dev:next": "next dev",
		"dev:webhook": "ngrok http --url=wired-legible-monster.ngrok-free.app 3000",
		"dev:inngest": "inngest-cli dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint",
		"lint:fix": "eslint --fix",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"db:migrate": "prisma migrate dev",
		"db:reset": "prisma migrate reset",
		"db:generate": "prisma generate",
		"db:studio": "prisma studio",
		"postinstall": "pnpm run db:generate"
	},
